{
  "name": "pictour-desktop",
  "version": "4.6.3",
  "private": true,
  "description": "PicTour Desktop - checkout presencial modular com painel ampliado v4.6.3.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "build:app": "npm run build && electron-builder --win nsis --x64",
    "pack:app": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "optionalDependencies": {
    "@imgly/background-removal": "^1.7.0",
    "onnxruntime-web": "1.21.0"
  },
  "build": {
    "appId": "app.pictour.desktop",
    "productName": "PicTour Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/PicTourIcon.png",
        "to": "PicTourIcon.png"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/PicTourIcon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PicTour Desktop"
    }
  },
  "author": "NoMercy Studio"
}
