PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
PICTOUR_CLOUD_API_KEY=pictour_dev_secret

# Storage padrão para desenvolvimento local.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./data/storage

# Para produção com Cloudflare R2 ou S3, altere STORAGE_DRIVER para r2 ou s3
# e preencha os campos abaixo. A galeria continua servindo previews pelo backend.
# STORAGE_DRIVER=r2
# R2_BUCKET=pictour-photos
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# S3_REGION=auto

# Exemplo AWS S3:
# STORAGE_DRIVER=s3
# S3_BUCKET=pictour-photos
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# Banco cloud: padrão JSON local. Para produção, use PostgreSQL.
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgresql://user:password@host:5432/pictour
# PGSSL=true

# Mercado Pago no backend cloud para checkout público + webhook automático.
# Use URL pública HTTPS real no PUBLIC_BASE_URL quando publicar em produção.
# MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
# MERCADO_PAGO_PUBLIC_BASE_URL=https://api.seudominio.com
# Token extra opcional para proteger /webhooks/mercado-pago?token=...
# PICTOUR_MP_WEBHOOK_TOKEN=troque-por-um-token-grande
# Em produção, deixe falso/ausente. Use true só em demo interna.
# PICTOUR_ALLOW_SIMULATED_PURCHASES=false
# CLOUD_PHOTO_PRICE_CENTS=4000 # fallback usado apenas se a sessão não tiver pacotes publicados pelo desktop

# Painel SaaS/admin comercial e servidor de licenças PicTour atual.
# Troque em produção. Nunca use o token padrão em servidor público.
PICTOUR_LICENSE_ADMIN_TOKEN=pictour_admin_secret

# Atualizações do PicTour Desktop
PICTOUR_LATEST_VERSION=4.6.3
PICTOUR_DOWNLOAD_URL=
PICTOUR_RELEASE_NOTES=Mercado Pago real no backend cloud|Webhook com liberação automática das fotos|Sync de vendas aprovadas para o Desktop|Entrega profissional liberada após pagamento

# v4.3 — storage cloud e download assinado
# STORAGE_PUBLIC_BASE_URL=https://cdn.seudominio.com/media
# PICTOUR_STORAGE_SIGNING_SECRET=troque-por-um-segredo-grande
# PICTOUR_STORAGE_SIGNED_TTL_SECONDS=900

# v4.3 — assinaturas/planos
# Os preços padrão podem ser sobrescritos no painel admin ou no body do upsert.
PICTOUR_PLAN_STARTER_CENTS=9900
PICTOUR_PLAN_PRO_CENTS=29900
PICTOUR_PLAN_ENTERPRISE_CENTS=99900
